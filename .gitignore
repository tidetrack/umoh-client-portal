# Environment & secrets
.env
*.env.local

# Auth credentials — subir manualmente via FTP, nunca al repo
dashboard/config/credentials.php
product/dashboard/config/credentials.php

# Python
__pycache__/
*.py[cod]
*.pyo
.venv/
venv/
dist/
build/
*.egg-info/

# Cowork local settings (no necesario en el repo)
.claude/
# Excepciones: los agentes del equipo sí van al repo
!.claude/agents/
!.claude/agents/**

# Credentials descargadas localmente
client_secret*.json
token.json
credentials.json
service_account.json
eco-league-*.json
*-sa-key.json
*.key.json

# SA keys y OAuth secrets en ops/ — nunca al repo
ops/production/environments/*.json
ops/testing/environments/*.json

# Brand assets & local tools — no necesarios en el repo
marca/
# scripts/ excluido salvo pipelines productivos que llama Actions.
# Truco: excluir contenido (scripts/*), no el directorio entero (scripts/),
# para que las excepciones siguientes funcionen en Git.
scripts/*
!.github/scripts/
!scripts/run_*.py
!scripts/sync_*.py
!scripts/backfill_*.py

# OS
.DS_Store
Thumbs.db

# Logs
*.log

# Docs internas (operativa privada — no va al repo)
docs-internal/

# MCP config local (entorno de desarrollo, no del repo)
.mcp.json

# Supabase temp/local
supabase/.temp/

# MeisterTask — data de cliente (CSVs exports). El template JSON sí va al repo.
Meistertask/**/*.csv
Meistertask/*.csv

# Inbox de ingesta manual — CSVs de cliente, jamás al repo
data/inbox/**/*.csv
data/inbox/processed/**
!data/inbox/README.md
!data/inbox/**/.gitkeep

# Assets de cliente sueltos en root (deben ir a clients/{slug}/assets/)
/prepaga_logo.webp
/*.webp
/*.psd
