# UMOH Client Portal — variables de entorno
# Copiar a .env y completar valores reales. NUNCA commitear .env.

# === Supabase ===
# URL del proyecto (público, no es secreto pero lo centralizamos acá)
SUPABASE_URL=https://xxxxxxxxxxxx.supabase.co

# Service role key — permisos totales sobre la DB. Solo backend / GitHub Actions.
SUPABASE_SERVICE_KEY=

# Publishable key (anon) — solo si el frontend habla directo con Supabase.
SUPABASE_PUBLISHABLE_KEY=

# === Google Ads (Fase 2) ===
GOOGLE_ADS_DEVELOPER_TOKEN=
GOOGLE_ADS_LOGIN_CUSTOMER_ID=
GOOGLE_ADS_CLIENT_ID=
GOOGLE_ADS_CLIENT_SECRET=
GOOGLE_ADS_REFRESH_TOKEN=

# === Meta Ads (Fase 3) ===
META_SYSTEM_USER_TOKEN=

# === Google Sheets (pipeline existente) ===
GOOGLE_SHEETS_SA_JSON=

# === MySQL Hostinger (auth de usuarios — Fase 4) ===
DB_HOST=
DB_NAME=
DB_USER=
DB_PASS=
